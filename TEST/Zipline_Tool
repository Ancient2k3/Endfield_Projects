set_props(slct_name, 1, {0, 0, 0}, {0.6, 0, 0.58, 0}, {0.25, 0, 0.05, 0}, true, 9, {255, 255, 0}, "Arcade", "[ nil ]", false)

zipline.Activated:Connect(function()
  local nearest_point = check_nearest_point(6.25)
  if data.on_zipline then tweening_to(selecting_zipline_pylon().Position) return end
  if nearest_point ~= nil then
    if not data.display.tool_cd then data.display.tool_cd = true
      notify("Không thể đặt một trụ zipline khác ở quá gần... ")
      task.wait(0.5) data.display.tool_cd = false
    end
  else
    if check_nearest_point(800) then
      built_cube()
    else
      if #zipline_folder:GetChildren() == 0 then
        built_cube()
      else
        notify("Ngoài phạm vi... có thể kết nối với trụ zipline khác!")
      end
    end
  end zipline.Name = "Zip Line"
end)

zipline.Equipped:Connect(function() data.tool_equip = true end)
zipline.Unequipped:Connect(function() data.tool_equip = false data.on_zipline = false
  zipline_select.ImageTransparency = 1
  slct_name.Visible = false
  bboardui.Adornee = nil_part
  reset_slct() remove_bv()
end)

rs.RenderStepped:Connect(function(dt)
  if dt and data.tool_equip and data.on_zipline then setup_selection_vfx() end
end)

rs.RenderStepped:Connect(function(dt)
  if plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health <= 0 then
    if not data.plr_died then
      data.plr_died = true
      zipline.Parent = nil_folder
    end
  else if data.plr_died then
      data.plr_died = false
      zipline.Parent = plr.Backpack
      cancel_zipline()
    end
  end
end)

